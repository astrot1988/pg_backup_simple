DATABASE_URL=postgresql://postgres:postgres@db:5432/app

CRON=0 2 * * *
TZ=UTC

BACKUP_DIR=/backups

KEEP_DAILY=7
KEEP_WEEKLY=8
KEEP_MONTHLY=12
KEEP_YEARLY=

# Optional when DATABASE_URL is not used:
# PGHOST=db
# PGPORT=5432
# PGDATABASE=app
# PGUSER=postgres
# PGPASSWORD=postgres

# Optional extra pg_dump flags:
# PGDUMP_EXTRA_OPTS=--clean --if-exists
